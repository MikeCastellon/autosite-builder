# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (required server + client)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare (required server)
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_ZONE_ID=...

# Custom domain feature
CUSTOM_DOMAIN_FALLBACK_ORIGIN=fallback.autocaregeniushub.com
DOMAIN_CONNECT_STATE_SECRET=generate-a-long-random-string
APP_URL=https://app.autocaregenius.com

# Postmark (required for domain-live notification)
POSTMARK_SERVER_TOKEN=...
POSTMARK_FROM_EMAIL=hello@autocaregeniushub.com

# Publishing
VITE_PUBLISH_DOMAIN=autocaregeniushub.com
PUBLISH_DOMAIN=autocaregeniushub.com

# Feature flag
VITE_CUSTOM_DOMAIN_ENABLED=false

# Stripe (subscription billing for Genius Websites Pro)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx

# CORS allowlist for browser-facing Netlify functions (auth-only endpoints).
# Comma-separated. Defaults are baked into _shared/cors.js for prod hosts +
# localhost dev — only set this var to override or add staging origins.
# Public widget endpoints (scheduler-slots, scheduler-config, support-slots,
# create-booking, support-book) intentionally accept any origin and ignore
# this list.
CORS_ALLOWED_ORIGINS=https://sitebuilder.autocaregenius.com,https://app.autocaregenius.com,https://autosite-builder.netlify.app

# Optional shared secret for triggering the domain-sweep cron from outside
# Netlify's scheduler (e.g. a maintenance script). When unset, only Netlify's
# own scheduled invocation (header x-netlify-event=schedule) is allowed.
# Generate with: openssl rand -hex 32
DOMAIN_SWEEP_TOKEN=

# Paywall testing allowlist. Comma-separated emails. Listed users see the
# upgrade gate on Bookings even if they're admins or have scheduler_enabled,
# so we can QA the Subscribe flow on a live admin account without exposing
# the paywall to anyone else. Read by src/lib/subscriptionGating.js
# (isPaywallTestUser). Leave empty to disable entirely.
VITE_PAYWALL_ALLOWLIST_EMAILS=
